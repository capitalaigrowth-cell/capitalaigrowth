# ============================================================
# Capital AI Growth — Environment Variables
# Copy this file to .env.local for local dev
# All values go into Vercel Environment Variables for production
# NEVER paste secrets into chat or commit .env.local to git
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# From: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Twilio ───────────────────────────────────────────────────
# From: https://console.twilio.com → Account Info (top of dashboard)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Your Twilio number — already purchased
TWILIO_PHONE_NUMBER=+61744287400
TWILIO_PHONE_NUMBER_SID=PNb02cfec15bba2589e6f7b14bb62b0843

# ── Vapi.ai ──────────────────────────────────────────────────
# From: https://dashboard.vapi.ai → Account → API Keys
VAPI_API_KEY=your_vapi_api_key_here
# Leave blank first run — set after running /api/vapi/setup
VAPI_ASSISTANT_ID=
# From: https://dashboard.vapi.ai → Webhooks → Secret
VAPI_WEBHOOK_SECRET=

# ── Anthropic ────────────────────────────────────────────────
# From: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google (Service Account) ─────────────────────────────────
# From: Google Cloud Console → IAM → Service Accounts → your account → Keys
# The email address shown on the service account
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# The private_key field from the downloaded JSON — include -----BEGIN/END PRIVATE KEY-----
# Replace newlines with \n when pasting into Vercel
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# Your Google Calendar ID — usually "primary" or find it in Calendar Settings
GOOGLE_CALENDAR_ID=primary
# The Google Sheet ID — from the URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_ID=your_sheet_id_here

# ── Resend ───────────────────────────────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
# Verified sender domain — set up in Resend dashboard
RESEND_FROM_EMAIL=andy@capitalaigrowth.com.au
RESEND_FROM_NAME=Andy Young | Capital AI Growth

# ── App Config ───────────────────────────────────────────────
# Your production Vercel URL (no trailing slash)
APP_URL=https://capitalaigrowth.vercel.app
# Andy's contact details for notifications and prep briefs
MY_EMAIL=andy@capitalaigrowth.com.au
MY_PHONE=+61400000000
MY_NAME=Andy Young

# ── CRM Destination ──────────────────────────────────────────
# Options: google_sheets | hubspot | pipedrive | airtable | webhook
CRM_DESTINATION=google_sheets

# ── Feature Flags ─────────────────────────────────────────────
# Set to "false" to disable a feature without redeploying
FEATURE_SMS_INBOUND=true
FEATURE_VAPI_CALLS=true
FEATURE_CALENDAR_BOOKING=true
FEATURE_EMAIL_CONFIRMATIONS=true
FEATURE_SHEET_SYNC=true

# ── Spend Caps (USD cents per month) ─────────────────────────
# Alert fires at 80% of each cap; hard stop at 100%
VAPI_MONTHLY_CAP_CENTS=5000
ANTHROPIC_MONTHLY_CAP_CENTS=2000
TWILIO_MONTHLY_CAP_CENTS=2000

# ── Timezone ──────────────────────────────────────────────────
TIMEZONE=Australia/Brisbane

# ── Booking Config ────────────────────────────────────────────
# How long each consultation is in minutes
BOOKING_DURATION_MINUTES=30
# How many slots to offer on the call
BOOKING_SLOTS_TO_OFFER=3
# How many hours ahead to look for slots
BOOKING_LOOKAHEAD_HOURS=72
# Business hours in Brisbane time (24h format)
BOOKING_HOURS_START=9
BOOKING_HOURS_END=17
